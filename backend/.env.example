DATABASE_URL=sqlite:///./data/raise_summit.db

# Celery (required for background mission search)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Search agent (required for mission create / POST /search-agent/run)
# Use "fixture" for local dev without API keys; use "tavily" (etc.) in production.
SEARCH_PROVIDER=fixture
TAVILY_API_KEY=

# Groq LLM — mission keywords, assist, outreach, and optional search query planning
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
